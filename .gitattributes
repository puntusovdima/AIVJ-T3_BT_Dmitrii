# Auto-normalize line endings for text files
* text=auto

# Unity text-based assets: treat as text, no merging
*.cs        text diff=csharp
*.shader    text
*.cginc     text
*.hlsl      text
*.uxml      text
*.uss       text
*.json      text
*.md        text
*.txt       text
*.meta      text -merge
*.unity     text -merge
*.asset     text -merge
*.prefab    text -merge
*.mat       text -merge
*.controller text -merge
*.inputactions text -merge

# Common binary asset types (no diff/merge)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.psd       binary
*.fbx       binary
*.obj       binary
*.wav       binary
*.mp3       binary
*.ogg       binary
*.dll       binary
